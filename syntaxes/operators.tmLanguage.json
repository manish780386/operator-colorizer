{
  "scopeName": "operator.colorizer.injection",
  "injectionSelector": "L:source -comment -string",
  "patterns": [
    { "include": "#arithmetic" },
    { "include": "#comparison" },
    { "include": "#logical" },
    { "include": "#assignment" },
    { "include": "#bitwise" }
  ],
  "repository": {
    "arithmetic": {
      "name": "keyword.operator.arithmetic.colorizer",
      "match": "(?<![=<>!\\-+*/%&|^])([+\\-*/%])(?![=+\\-*/%&|^])"
    },
    "comparison": {
      "name": "keyword.operator.comparison.colorizer",
      "match": "(===|!==|==|!=|>=|<=|<(?!<)|>(?!>))"
    },
    "logical": {
      "name": "keyword.operator.logical.colorizer",
      "match": "(and|or|not|&&|\\|\\||!(?!=)|\\?\\?)"
    },
    "assignment": {
      "name": "keyword.operator.assignment.colorizer",
      "match": "(\\+=|-=|\\*=|/=|%=|\\*\\*=|//=|=(?![=>]))"
    },
    "bitwise": {
      "name": "keyword.operator.bitwise.colorizer",
      "match": "(&(?!&)|\\|(?!\\|)|\\^|~|<<|>>)"
    }
  }
}